# Arc Pass — environment variables
# Copy to .env and fill in what you have. Missing production integrations
# fail closed; they never create fake eligibility, tiers, or mint success.
#
# Never put real secrets in this file — it's the committed template.
# Real values go in .env (gitignored). See .env.production.example for
# what differs in a deployed environment.

# --- Required ---

# Postgres connection string (e.g. a Neon pooled connection string).
DATABASE_URL=
SESSION_SECRET=
APP_URL=http://localhost:5173

# Port each dev server binds to. Vite's dev server also proxies /api and
# /uploads to this same value for the API server (see API_PROXY_TARGET).
PORT=5173

# Vite base path — normally just "/".
BASE_PATH=/

NODE_ENV=development
DEV_DATABASE_URL=

# --- Frontend <-> API wiring (local dev only) ---

# Where the Vite dev server proxies /api and /uploads. Only needed when
# running the frontend and API as separate processes on separate ports
# (i.e. not behind Replit's own router or a production reverse proxy).
API_PROXY_TARGET=http://localhost:8080

# Where OAuth callbacks and the login modal redirect back to after auth.
FRONTEND_URL=http://localhost:5173

# --- Logging ---
LOG_LEVEL=info

# --- Signed authorizations ---
# 32+ random bytes, base64-encoded (e.g. `openssl rand -base64 32` or
# `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`).
# Falls back to an ephemeral in-memory key in dev — set a persistent value
# in production or every issued ticket/OAuth state invalidates on restart.
MINT_SIGNING_KEY=
OAUTH_STATE_SIGNING_KEY=

# --- File uploads (company logos, tier emblems) ---
# Local-disk storage by default. Point at a mounted volume, or swap
# artifacts/api-server/src/lib/uploads.ts for an S3/R2/Cloudinary-backed
# implementation in production.
UPLOADS_DIR=./uploads

# --- OAuth: X (Founder login) ---
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8080/api/auth/x/callback

# --- OAuth: Discord (X or Discord is sufficient) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/api/auth/discord/callback
# Optional: checks Arc Discord server membership as a supporting signal.
ARC_DISCORD_GUILD_ID=

# --- OAuth: GitHub (required account link before claiming) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/github/callback

# --- Onchain minting ---
# See contracts/README.md — contracts are written but not yet deployed.
# All four of CHAIN_RPC_URL/RELAYER_PRIVATE_KEY/FOUNDER_PASS_CONTRACT_ADDRESS/
# BUILDER_PASS_CONTRACT_ADDRESS must be set together. Missing configuration
# disables minting; it never creates a fake transaction.
CHAIN_RPC_URL=
ARC_CHAIN_ID=
RELAYER_PRIVATE_KEY=
FOUNDER_PASS_CONTRACT_ADDRESS=
BUILDER_PASS_CONTRACT_ADDRESS=

# Indexer/explorer API for deterministic onchain activity counts
# (qualifying transactions, valid deployed contracts). Without this,
# verification fails closed with a temporary-unavailable response.
EXPLORER_API_URL=
EXPLORER_API_KEY=

# --- Founder application (public URL is safe for Vite) ---
VITE_FOUNDER_APPLICATION_FORM_URL=
TYPEFORM_FORM_ID=
TYPEFORM_API_TOKEN=
TYPEFORM_WEBHOOK_SECRET=

# --- Wallet UI public configuration ---
VITE_ARC_CHAIN_ID=
VITE_ARC_RPC_URL=

# Development mocks require deliberate opt-in and are rejected in production.
ENABLE_DEV_MOCKS=false

# Builder contract supply is unlimited. This controls the current off-chain
# release allocation and can be raised for later phases without redeploying.
BUILDER_PHASE_NAME=Wave 1
BUILDER_PHASE_CLAIM_LIMIT=2499

# Explicit local QA fixtures. These flags and values are rejected when
# NODE_ENV=production. X test identities still require successful real X
# OAuth, and Builder claims still require a wallet ownership signature.
ENABLE_DEV_TEST_IDENTITIES=false
DEV_ELIGIBLE_X_HANDLES=
ENABLE_DEV_ADMIN_BOOTSTRAP=false
DEV_ADMIN_BOOTSTRAP_EMAIL=

# Dedicated admin bootstrap/session values. Passwords are never placed in VITE variables.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
