# Arc Pass — PRODUCTION environment differences from .env.example.
# This is a template, not a real file to load — most secrets are the same
# values as local (new OAuth app credentials pointed at the production
# redirect URIs below), not different secrets. Fill in and set these on
# your actual deployment platform (Replit deployment secrets, etc.) —
# don't create a real `.env.production` file that could get committed.

NODE_ENV=production
DEV_DATABASE_URL=

# The API server serves the built frontend + API on the same origin in
# production, so the local-dev-only proxy isn't used.
# API_PROXY_TARGET is not needed in production.

# Your real deployed domain.
FRONTEND_URL=https://arc.webcoinlabs.com
APP_URL=https://arc.webcoinlabs.com
SESSION_SECRET=
ENABLE_DEV_MOCKS=false
BUILDER_PHASE_NAME=Wave 1
BUILDER_PHASE_CLAIM_LIMIT=2499
ENABLE_DEV_TEST_IDENTITIES=false
DEV_ELIGIBLE_X_HANDLES=
ENABLE_DEV_ADMIN_BOOTSTRAP=false
DEV_ADMIN_BOOTSTRAP_EMAIL=

# Every OAuth app's redirect URI must be registered with that provider
# for BOTH the local callback (http://localhost:8080/...) and this one —
# most providers let you register multiple redirect URIs on one app, so
# this is usually the same X_CLIENT_ID/GITHUB_CLIENT_ID etc. as local, just
# with a second registered redirect URI.
X_REDIRECT_URI=https://arc.webcoinlabs.com/api/auth/x/callback
DISCORD_REDIRECT_URI=https://arc.webcoinlabs.com/api/auth/discord/callback
ARC_DISCORD_GUILD_ID=
# Optional: comma-separated IDs for the two Builder Pass role checks.
ARC_DISCORD_PRIMARY_ROLE_IDS=
# Optional server-only bot token for resolving Arc role IDs to names.
DISCORD_BOT_TOKEN=
GITHUB_REDIRECT_URI=https://arc.webcoinlabs.com/api/auth/github/callback

# Generate distinct, persistent signing keys for production — do not reuse
# the local dev ones:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MINT_SIGNING_KEY=
OAUTH_STATE_SIGNING_KEY=

# Cloudflare R2 object storage. Set all five values together. Use a custom
# domain for CLOUDFLARE_R2_PUBLIC_URL in production; r2.dev is for development.
UPLOADS_DIR=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=

# Optional Gemini Chat Support uses GEMINI_API_KEY and defaults to
# GEMINI_SUPPORT_MODEL=gemini-3.5-flash. It is limited to five replies per
# privacy-preserving visitor fingerprint every 24 hours and never determines
# eligibility, tiers, wallet ownership, claims, or mints.
GEMINI_API_KEY=
GEMINI_SUPPORT_MODEL=gemini-3.5-flash
GEMINI_ANALYSIS_MODEL=gemini-3.5-flash

# Blockscout activity and gas API. The public Arcscan base also works, but
# PRO provides higher limits and accepts the key shown on the Blockscout page.
EXPLORER_API_URL=https://api.blockscout.com/5042002/api/v2
EXPLORER_API_KEY=

# Secondary address-history indexer for Arc Testnet. This is used only if the
# primary Arcscan pagination fails; set the Envio token in Railway, never in a
# VITE_ variable. Leave the URL blank to use https://arc-testnet.hypersync.xyz.
ENVIO_HYPERSYNC_API_TOKEN=
ENVIO_HYPERSYNC_URL=

# Everything else (DATABASE_URL, CHAIN_RPC_URL, ARC_CHAIN_ID,
# RELAYER_PRIVATE_KEY, and contract addresses) carries
# over as the same real values — just make sure DATABASE_URL points at
# your production database, not a local/dev one, and that
# RELAYER_PRIVATE_KEY is funded on whatever network you actually deploy
# the contracts to.
