# Arc Pass — PRODUCTION environment differences from .env.example.
# This is a template, not a real file to load — most secrets are the same
# values as local (new OAuth app credentials pointed at the production
# redirect URIs below), not different secrets. Fill in and set these on
# your actual deployment platform (Replit deployment secrets, etc.) —
# don't create a real `.env.production` file that could get committed.

NODE_ENV=production
DEV_DATABASE_URL=

# The API server serves the built frontend + API on the same origin in
# production, so the local-dev-only proxy isn't used.
# API_PROXY_TARGET is not needed in production.

# Your real deployed domain.
FRONTEND_URL=https://arc.webcoinlabs.com
APP_URL=https://arc.webcoinlabs.com
SESSION_SECRET=
ENABLE_DEV_MOCKS=false
ENABLE_DEV_TEST_IDENTITIES=false
DEV_ELIGIBLE_X_HANDLES=
ENABLE_DEV_ADMIN_BOOTSTRAP=false
DEV_ADMIN_BOOTSTRAP_EMAIL=

# Every OAuth app's redirect URI must be registered with that provider
# for BOTH the local callback (http://localhost:8080/...) and this one —
# most providers let you register multiple redirect URIs on one app, so
# this is usually the same X_CLIENT_ID/GITHUB_CLIENT_ID etc. as local, just
# with a second registered redirect URI.
X_REDIRECT_URI=https://arc.webcoinlabs.com/api/auth/x/callback
DISCORD_REDIRECT_URI=https://arc.webcoinlabs.com/api/auth/discord/callback

# Generate distinct, persistent signing keys for production — do not reuse
# the local dev ones:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MINT_SIGNING_KEY=
OAUTH_STATE_SIGNING_KEY=

# Point at persistent storage in production rather than local disk —
# see the TODO in artifacts/api-server/src/lib/uploads.ts.
UPLOADS_DIR=

# Everything else (DATABASE_URL, GEMINI_API_KEY, CHAIN_RPC_URL,
# RELAYER_PRIVATE_KEY, contract addresses, EXPLORER_API_URL/KEY) carries
# over as the same real values — just make sure DATABASE_URL points at
# your production database, not a local/dev one, and that
# RELAYER_PRIVATE_KEY is funded on whatever network you actually deploy
# the contracts to.
