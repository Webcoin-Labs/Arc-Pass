{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "preinstall": "node ./scripts/enforce-pnpm.mjs",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "contracts:compile": "node ./scripts/compile-contracts.mjs",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "dependencies": {
    "@replit/connectors-sdk": "^0.4.1"
  },
  "devDependencies": {
    "prettier": "^3.9.5",
    "solc": "0.8.30",
    "typescript": "~5.9.3"
  },
  "pnpm": {
    "overrides": {
      "axios": "1.18.1",
      "uuid": "11.1.1",
      "ws": "8.21.0"
    }
  }
}
