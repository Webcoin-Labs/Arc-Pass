{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/arc-pass build",
  "outputDirectory": "artifacts/arc-pass/dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://arc-pass-api-production.up.railway.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://arc-pass-api-production.up.railway.app/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
